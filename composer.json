{
    "name": "janickiy/php-newsletter",
    "type": "project",
    "description": "Self-hosted email marketing and subscriber management system.",
    "keywords": ["email-marketing", "laravel", "newsletter"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "ext-mbstring": "*",
        "ext-zip": "*",
        "guzzlehttp/guzzle": "^7.2",
        "laravelcollective/html": "^6.4.1",
        "laravel/framework": "^10.10",
        "laravel/sanctum": "^3.3",
        "laravel/tinker": "^2.8",
        "league/csv": "^9.15",
        "phpmailer/phpmailer": "^6.9",
        "phpoffice/phpspreadsheet": "^2.0",
        "yajra/laravel-datatables-buttons": "^10.0",
        "yajra/laravel-datatables-html": "^10.12"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "@php artisan test"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2.29"
        },
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "abandoned": "report",
            "block-insecure": true,
            "ignore": {
                "PKSA-3r5d-mb8f-1qw9": "Laravel 10 is retained by explicit project requirement; migration to a supported framework branch is tracked separately.",
                "PKSA-m5cs-t1y6-qpcs": "Laravel 10 is retained by explicit project requirement; this application does not register signed URL routes.",
                "PKSA-mdq4-51ck-6kdq": "Laravel 10 is retained by explicit project requirement; migration to a supported framework branch is tracked separately."
            }
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
